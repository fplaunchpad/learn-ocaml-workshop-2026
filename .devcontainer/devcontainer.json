{
  "name": "CSE Exebit OCaml Workshop (DockerHub image)",
  "image": "durwasa/ocaml-workshop:latest",
  "remoteUser": "vscode",
  "userEnvProbe": "loginInteractiveShell",
  "customizations": {
    "vscode": {
      "extensions": ["ocamllabs.ocaml-platform"],
      "settings": {
        "ocaml.sandbox": {
          "kind": "opam",
          "switch": "default"
        },
        "github.copilot.enable": { "*": false }
      }
    }
  },
  "mounts": [
    "source=dune-cache,target=/home/vscode/.cache/dune,type=volume"
  ],
  "remoteEnv": { "DUNE_CACHE_ROOT": "/home/vscode/.cache/dune" },
  "hostRequirements": {
    "cpus": 4,
    "memory": "2gb",
    "storage": "8gb"
  }
}